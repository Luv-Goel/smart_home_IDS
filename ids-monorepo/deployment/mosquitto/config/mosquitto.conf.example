# Basic Mosquitto Configuration for IDS

# Allow anonymous access for local development/testing (change in production)
allow_anonymous true

# Standard MQTT listener
listener 1883 0.0.0.0

# WebSockets listener
listener 9001 0.0.0.0
protocol websockets

# Persistence
persistence true
persistence_location /mosquitto/data/

# Logging
log_dest file /mosquitto/log/mosquitto.log
log_type error
log_type warning
log_type notice
log_type information
